# Required: your OpenAI-compatible API key
OPENAI_API_KEY=

# Optional: custom base URL for OpenAI-compatible endpoints (e.g. Ollama, Azure, local proxy)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Optional: model ID to use (default: gpt-4o)
# OPENAI_MODEL=gpt-4o

# Optional: max agent loop iterations (default: 12)
# MAX_STEPS=12
